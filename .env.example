# Server
PORT=3000
JWT_SECRET=your-jwt-secret-change-this
NODE_ENV=development

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key-from-aistudio.google.com

# Email notifications (optional — leave blank to disable)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=VU Budget <your-gmail@gmail.com>
APP_URL=https://budget.vidalpablo.com

# Passkey / WebAuthn (optional — derived from APP_URL if not set)
# RP_ID=budget.vidalpablo.com
# RP_ORIGIN=https://budget.vidalpablo.com
